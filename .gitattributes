# Normalize all text files to LF in the repo and on checkout, so Windows
# checkouts don't produce CRLF working copies that fail Prettier's LF check.
* text=auto eol=lf

# Keep binary assets untouched.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
