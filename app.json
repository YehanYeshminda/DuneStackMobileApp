{
  "expo": {
    "name": "DuneStack Places",
    "slug": "dunestack-places",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "DuneStack Places uses the camera to take photos for places you choose to save locally.",
        "NSLocationWhenInUseUsageDescription": "DuneStack Places uses your location only when you save a place, and keeps it on this device."
      }
    },
    "android": {
      "permissions": [
        "CAMERA",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#F4EFE6",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.yehannnnn.dunestackplaces"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-maps",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#B4744A",
          "resizeMode": "contain",
          "imageWidth": 200
        }
      ]
    ],
    "scheme": "dunestack-places"
  }
}
